---
import type { CollectionEntry } from 'astro:content';
import ArtworkImage from './ArtworkImage.astro';
import CompareButton from './CompareButton.astro';

interface Props {
  artwork: CollectionEntry<'artwork'>;
  priority?: boolean;
}
const { artwork, priority = false } = Astro.props;
---
<article class="artwork-card" data-category={artwork.data.category} data-year={artwork.data.year}>
  <a class="image-link" href={`/works/${artwork.id}/`}>
    <ArtworkImage
      publicId={artwork.data.publicId}
      alt={artwork.data.alt}
      preset="gallery"
      eager={priority}
      sizes="(max-width: 720px) 100vw, (max-width: 1100px) 50vw, 33vw"
    />
  </a>
  <div class="card-meta">
    <div>
      <h2><a href={`/works/${artwork.id}/`}>{artwork.data.title}</a></h2>
      <p>{artwork.data.year}</p>
    </div>
    <CompareButton id={artwork.id} title={artwork.data.title} />
  </div>
</article>

<style>
  .artwork-card { min-width: 0; }
  .image-link { display: block; background: var(--color-surface); }
  .image-link :global(img) {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: contain;
    background: var(--color-surface);
  }
  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: var(--space-4);
    padding-top: var(--space-3);
  }
  h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 400;
    line-height: 1.1;
  }
  p {
    margin: 0.2rem 0 0;
    color: var(--color-muted);
    font-size: var(--step--1);
  }
</style>
