---
const path = Astro.url.pathname;
const links = [
  ['/works/', 'Works'],
  ['/exhibitions/', 'Exhibitions'],
  ['/archive/', 'Archive'],
  ['/compare/', 'Compare'],
  ['/cv/', 'CV'],
  ['/about/', 'About']
];
---
<header class="site-header">
  <div class="header-inner container">
    <a class="wordmark" href="/" aria-label="Christopher Martino, home">Christopher Martino</a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      {links.map(([href, label]) => (
        <a href={href} aria-current={path.startsWith(href) ? 'page' : undefined}>{label}</a>
      ))}
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle color theme">
        <span aria-hidden="true">◐</span>
        <span>Theme</span>
      </button>
    </nav>

    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu">
      Menu
    </button>
  </div>

  <div id="mobile-menu" class="mobile-menu" hidden>
    <nav class="mobile-nav container" aria-label="Mobile navigation">
      {links.map(([href, label]) => <a href={href}>{label}</a>)}
      <button class="theme-toggle" type="button" data-theme-toggle>
        <span aria-hidden="true">◐</span>
        <span>Toggle theme</span>
      </button>
    </nav>
  </div>
</header>

<script>
  const bindMenu = () => {
    const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
    const menu = document.querySelector<HTMLElement>('#mobile-menu');
    if (!toggle || !menu || toggle.dataset.bound === 'true') return;
    toggle.dataset.bound = 'true';

    const close = () => {
      toggle.setAttribute('aria-expanded', 'false');
      menu.hidden = true;
      document.body.classList.remove('menu-open');
      toggle.textContent = 'Menu';
    };

    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      if (open) close();
      else {
        toggle.setAttribute('aria-expanded', 'true');
        menu.hidden = false;
        document.body.classList.add('menu-open');
        toggle.textContent = 'Close';
      }
    });

    menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', close));
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') close();
    });
  };

  document.addEventListener('astro:page-load', bindMenu);
  bindMenu();
</script>

<style>
  .site-header {
    position: relative;
    z-index: 20;
    min-height: var(--header-height);
    border-bottom: var(--border);
    background: color-mix(in srgb, var(--color-bg) 94%, transparent);
    backdrop-filter: blur(12px);
  }

  .header-inner {
    min-height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: 1.65rem;
    line-height: 1;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    font-size: var(--step--1);
  }

  .desktop-nav a[aria-current='page'] {
    text-decoration: underline;
    text-underline-offset: 0.3em;
  }

  .menu-toggle {
    border: 0;
    background: transparent;
    padding: 0.4rem;
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 2.4rem;
    border: var(--border);
    border-radius: 999px;
    background: var(--color-surface);
    color: var(--color-text);
    padding: 0.45rem 0.8rem;
    font: inherit;
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .theme-toggle:hover {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 3px;
  }

  .menu-toggle { display: none; }

  .mobile-menu {
    position: absolute;
    inset: 100% 0 auto;
    min-height: calc(100vh - var(--header-height));
    background: var(--color-bg);
    border-top: var(--border);
  }

  .mobile-nav {
    display: grid;
    gap: var(--space-4);
    padding-block: var(--space-8);
  }

  .mobile-nav a {
    font-family: var(--font-display);
    font-size: var(--step-2);
  }

  @media (max-width: 820px) {
    .desktop-nav { display: none; }
    .menu-toggle { display: block; }
  }
</style>
