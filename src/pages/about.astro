---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const page = await getEntry('pages', 'about');
if (!page) throw new Error('Missing src/content/pages/about.md');
const { Content } = await render(page);
---
<BaseLayout title={page.data.title}>
  <div class="page container editorial-page">
    <header>
      <p class="eyebrow">Artist</p>
      <h1 class="page-title">{page.data.title}</h1>
    </header>
    <div class="prose"><Content /></div>
  </div>
</BaseLayout>

<style>
  .editorial-page {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-16);
  }
  @media (max-width: 720px) {
    .editorial-page { grid-template-columns: 1fr; gap: var(--space-8); }
  }
</style>
