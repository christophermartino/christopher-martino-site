---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categoryLabel } from '../../lib/artwork';

const works = await getCollection('artwork');
const exhibitions = await getCollection('exhibitions');

const years = [...new Set([
  ...works.map((work) => work.data.year),
  ...exhibitions.map((item) => item.data.startDate.getFullYear())
])].sort((a, b) => b - a);
---
<BaseLayout title="Archive">
  <div class="page container">
    <header class="archive-header">
      <p class="eyebrow">Chronological Index</p>
      <h1 class="page-title">Archive</h1>
      <p>Works and exhibitions organized by year.</p>
    </header>

    <div class="timeline">
      {years.map((year) => {
        const yearWorks = works
          .filter((work) => work.data.year === year)
          .sort((a, b) => a.data.order - b.data.order);
        const yearExhibitions = exhibitions
          .filter((item) => item.data.startDate.getFullYear() === year);

        return (
          <section class="year-group">
            <h2>{year}</h2>
            <div class="year-content">
              {(['painting', 'drawing', 'digital'] as const).map((category) => {
                const items = yearWorks.filter((work) => work.data.category === category);
                if (!items.length) return null;
                return (
                  <div class="archive-category">
                    <h3>{categoryLabel(category)}</h3>
                    <ul>
                      {items.map((work) => (
                        <li>
                          <a href={`/works/${work.id}/`}>
                            <span>{work.data.title}</span>
                            <span>{work.data.medium}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                );
              })}
              {yearExhibitions.length > 0 && (
                <div class="archive-category">
                  <h3>Exhibitions</h3>
                  <ul>
                    {yearExhibitions.map((item) => (
                      <li>
                        <a href="/exhibitions/">
                          <span>{item.data.title}</span>
                          <span>{item.data.venue}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </section>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
  .archive-header {
    display: grid;
    gap: var(--space-4);
    margin-bottom: var(--space-16);
  }
  .archive-header p:last-child {
    margin: 0;
    color: var(--color-muted);
  }
  .timeline { border-top: var(--border); }
  .year-group {
    display: grid;
    grid-template-columns: minmax(7rem, 1fr) 4fr;
    gap: var(--space-8);
    padding-block: var(--space-12);
    border-bottom: var(--border);
  }
  .year-group > h2 {
    margin: 0;
    position: sticky;
    top: var(--space-6);
    align-self: start;
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 400;
    line-height: 1;
  }
  .year-content { display: grid; gap: var(--space-8); }
  .archive-category h3 {
    margin: 0 0 var(--space-3);
    color: var(--color-muted);
    font-size: var(--step--1);
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  ul { list-style: none; margin: 0; padding: 0; }
  li { border-top: var(--border); }
  li a {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    padding-block: var(--space-3);
  }
  li span:last-child {
    color: var(--color-muted);
    text-align: right;
    font-size: var(--step--1);
  }
  @media (max-width: 650px) {
    .year-group { grid-template-columns: 1fr; }
    .year-group > h2 { position: static; }
  }
</style>
