---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const page = await getEntry('pages', 'contact');
if (!page) throw new Error('Missing src/content/pages/contact.md');
const { Content } = await render(page);
---
<BaseLayout title={page.data.title}>
  <div class="page container contact-page">
    <p class="eyebrow">Inquiries</p>
    <h1 class="display">{page.data.title}</h1>
    {page.data.email && <a class="email" href={`mailto:${page.data.email}`}>{page.data.email}</a>}
    <div class="prose"><Content /></div>
  </div>
</BaseLayout>

<style>
  .contact-page {
    min-height: 65vh;
    display: grid;
    align-content: center;
    justify-items: start;
    gap: var(--space-6);
  }
  .email { font-size: var(--step-1); text-decoration: underline; text-underline-offset: 0.25em; }
</style>
