---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const exhibitions = (await getCollection('exhibitions'))
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());
---
<BaseLayout title="Exhibitions">
  <div class="page container">
    <header class="page-header">
      <p class="eyebrow">Selected History</p>
      <h1 class="page-title">Exhibitions</h1>
    </header>

    <div class="exhibition-list">
      {exhibitions.map((item) => (
        <article>
          <time>{item.data.startDate.getFullYear()}</time>
          <div>
            <h2>{item.data.title}</h2>
            <p>{item.data.venue}, {item.data.location}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-header { margin-bottom: var(--space-12); }
  .exhibition-list { border-top: var(--border); }
  article {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: var(--space-8);
    border-bottom: var(--border);
    padding-block: var(--space-6);
  }
  time { color: var(--color-muted); }
  h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 400;
  }
  p { margin: 0.3rem 0 0; color: var(--color-muted); }
  @media (max-width: 600px) {
    article { grid-template-columns: 1fr; gap: var(--space-2); }
  }
</style>
