---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArtworkGrid from '../components/Artwork/ArtworkGrid.astro';
import CompareTray from '../components/Compare/CompareTray.astro';
import ArtworkImage from '../components/Artwork/ArtworkImage.astro';
import { sortArtwork } from '../lib/artwork';

const allWorks = sortArtwork(await getCollection('artwork'));
const selected = allWorks.filter((work) => work.data.featured).slice(0, 6);
const exhibitions = (await getCollection('exhibitions'))
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());
const featuredExhibition = exhibitions.find((item) => item.data.featured) || exhibitions[0];
---
<BaseLayout>

  <section class="section container">
    <div class="section-header">
      <h2 class="section-title">Selected Works</h2>
      <a class="text-link" href="/works/">View all works →</a>
    </div>
    <ArtworkGrid works={selected} priorityCount={3} />
  </section>

  {featuredExhibition && (
    <section class="section container exhibition-feature">
      <div>
        <p class="eyebrow">Selected Exhibition</p>
        <h2 class="section-title">{featuredExhibition.data.title}</h2>
        <p>{featuredExhibition.data.venue}<br />{featuredExhibition.data.location}</p>
      </div>
      <div class="exhibition-date">
        {featuredExhibition.data.startDate.getFullYear()}
      </div>
    </section>
  )}

  <section class="section container archive-promo">
    <p class="eyebrow">Chronological Index</p>
    <h2 class="display">Archive</h2>
    <p>Browse works and exhibitions across years, categories, and series.</p>
    <a class="text-link" href="/archive/">Enter archive →</a>
  </section>

  <CompareTray />
</BaseLayout>

<style>
  .home-intro {
    min-height: min(68vh, 48rem);
    display: grid;
    align-content: center;
    padding-block: var(--space-16);
  }
  .intro-copy {
    margin: var(--space-8) 0 0;
    color: var(--color-muted);
  }
  .exhibition-feature {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-8);
  }
  .exhibition-feature p:not(.eyebrow) { color: var(--color-muted); }
  .exhibition-date {
    font-family: var(--font-display);
    font-size: var(--step-4);
    line-height: 1;
  }
  .archive-promo {
    min-height: 32rem;
    display: grid;
    align-content: center;
    justify-items: start;
  }
  .archive-promo > p:not(.eyebrow) {
    max-width: 30rem;
    color: var(--color-muted);
  }
  @media (max-width: 620px) {
    .home-intro { min-height: 56vh; }
    .exhibition-feature { grid-template-columns: 1fr; }
  }
